graph TD
    %% Styles
    classDef perimeter fill:#E63946,stroke:#1D3557,stroke-width:2px,color:white;
    classDef appsec fill:#F4A261,stroke:#1D3557,stroke-width:2px,color:white;
    classDef iam fill:#2A9D8F,stroke:#1D3557,stroke-width:2px,color:white;
    classDef logic fill:#457B9D,stroke:#1D3557,stroke-width:2px,color:white;
    classDef data fill:#1D3557,stroke:#000000,stroke-width:2px,color:white;

    subgraph Layer1 ["🛡️ Layer 1: Perimeter & Network"]
        User[User Request]
        Nginx[Nginx Reverse Proxy]
        RateLimit["Rate Limiting (DDOS Protection)"]
        
        User --> Nginx
        Nginx --> RateLimit
    end

    subgraph Layer2 ["🔒 Layer 2: Application Security"]
        Headers["Security Headers (CSP, HSTS)"]
        Sanitize["Input Sanitization (XSS, NoSQLi)"]
        
        RateLimit --> Headers
        Headers --> Sanitize
    end

    subgraph Layer3 ["🔑 Layer 3: Identity & Access (IAM)"]
        Auth["Auth Middleware (JWT)"]
        RBAC["IAM / RBAC Check"]
        
        Sanitize --> Auth
        Auth --> RBAC
    end

    subgraph Layer4 ["💼 Layer 4: Business Logic Security"]
        VaultCheck["Vault Security"]
        Audit["Audit Logging"]
        FileScan["File Type/MIME Validation"]
        
        RBAC --> VaultCheck
        VaultCheck --> FileScan
        VaultCheck -.->|Log Access| Audit
    end

    subgraph Layer5 ["💾 Layer 5: Data Protection"]
        Encrypt["AES-256-GCM Encryption"]
        DB[("MongoDB Atlas")]
        Storage["Secure Storage"]
        
        FileScan --> Encrypt
        Encrypt --> DB
        Encrypt --> Storage
    end

    %% Styling
    class User,Nginx,RateLimit perimeter;
    class Headers,Sanitize appsec;
    class Auth,RBAC iam;
    class VaultCheck,Audit,FileScan logic;
    class Encrypt,DB,Storage data;
