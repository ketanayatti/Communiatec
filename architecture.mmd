graph TD
    %% Styles
    classDef aws fill:#FF9900,stroke:#232F3E,stroke-width:2px,color:white;
    classDef github fill:#24292e,stroke:#white,stroke-width:2px,color:white;
    classDef local fill:#3b82f6,stroke:#1d4ed8,stroke-width:2px,color:white;
    classDef db fill:#47A248,stroke:#white,stroke-width:2px,color:white;

    subgraph Local_Env [💻 Local Development]
        Dev[Developer]
        Code[Source Code]
        Dev -->|Git Push| Code
    end

    subgraph GitHub_Ecosystem [🚀 GitHub Ecosystem]
        Repo[GitHub Repository]
        
        subgraph Actions [GitHub Actions CI/CD]
            Trigger[Push to Master]
            Build[Build React App]
            Compress[Compress Artifacts]
            Transfer[SCP/Rsync to EC2]
        end
        
        Code -->|Triggers| Repo
        Repo -->|Event| Trigger
        Trigger --> Build
        Build --> Compress
        Compress --> Transfer
    end

    subgraph AWS_Cloud [☁️ AWS Cloud Infrastructure]
        subgraph EC2 ["EC2 Instance (t3.micro)"]
            Nginx[Nginx Reverse Proxy]
            
            subgraph App_Layer [Application Layer]
                Frontend[Static React Files]
                Backend["Node.js Server (PM2)"]
            end
            
            Transfer -->|Deploys to| Frontend
            Transfer -->|Updates| Backend
            Nginx -->|Serves| Frontend
            Nginx -->|Proxy Pass /api| Backend
        end
    end

    subgraph External_Services [🌐 External Services]
        Mongo[(MongoDB Atlas)]
        Cloudinary[Cloudinary Storage]
        Gemini[Gemini AI API]
    end

    Backend <-->|Data| Mongo
    Backend <-->|Media| Cloudinary
    Backend <-->|AI| Gemini

    %% Styling
    class EC2,App_Layer aws;
    class Repo,Actions,Trigger,Build,Compress,Transfer github;
    class Dev,Code local;
    class Mongo,Cloudinary,Gemini db;